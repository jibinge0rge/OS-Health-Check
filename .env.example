# Copy to .env for local Docker / compose (never commit .env)
# Portainer: set these in the stack Environment section instead.

# Host port published by compose (container still listens on APP_PORT inside)
# APP_PORT=8000

# Set true for live reload (default in docker-compose.yml)
# UVICORN_RELOAD=true

# PostgreSQL (vendor lookup caches). Compose defaults work with the bundled db service.
POSTGRES_USER=oshealth
POSTGRES_PASSWORD=oshealth
POSTGRES_DB=oshealth
DATABASE_URL=postgresql://oshealth:oshealth@db:5432/oshealth

# Optional AI providers (AI match stays off in the UI until enabled)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

GEMINI_API_KEY=
# GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
